extends layout

block content
  section.card
    h2= brand
    h3 Modelos intervencionados
    ul.models
      each model in models
        li= model

  section.card
    h3 Registos da marca
    table.records
      thead
        tr
          th _id
          th Data
          th Nome
          th Matricula
          th Marca
          th Nr Intervencoes
      tbody
        each repair in repairs
          tr
            td
              a(href=repair.detailUrl)= repair._id
            td= repair.data
            td= repair.nome
            td= repair.viatura.matricula
            td= repair.viatura.marca
            td= repair.nr_intervencoes
